# ThreatScope Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required: AI Configuration
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# =============================================================================
# Optional: API Server
# =============================================================================
THREATSCOPE_API_HOST=0.0.0.0
THREATSCOPE_API_PORT=8000
THREATSCOPE_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# Optional: Analysis Settings
# =============================================================================
THREATSCOPE_ANALYSIS_DEFAULT_TIMEOUT=300
THREATSCOPE_ANALYSIS_DYNAMIC_ANALYSIS_TIMEOUT=30
THREATSCOPE_ANALYSIS_ENABLE_DYNAMIC_ANALYSIS=true
THREATSCOPE_ANALYSIS_ENABLE_GHIDRA_ANALYSIS=true
THREATSCOPE_ANALYSIS_YARA_RULES_PATH=rules/yara

# =============================================================================
# Optional: Ghidra Settings
# =============================================================================
THREATSCOPE_GHIDRA_BASE_URL=http://localhost:8000
THREATSCOPE_GHIDRA_POOL_SIZE=1
THREATSCOPE_GHIDRA_DOCKER_IMAGE=threatscope/ghidra:latest
THREATSCOPE_GHIDRA_MEMORY_LIMIT=4g
THREATSCOPE_GHIDRA_SERVICE_MODE=subprocess

# =============================================================================
# Optional: Worker Settings
# =============================================================================
THREATSCOPE_WORKERS_STAGE_1_4=4
THREATSCOPE_WORKERS_STAGE_6=4
THREATSCOPE_WORKERS_DYNAMIC_ANALYSIS=2

# =============================================================================
# Optional: Database
# =============================================================================
THREATSCOPE_DB_PATH=.threatscope/tasks.db
THREATSCOPE_DB_TIMEOUT=30.0

# =============================================================================
# Optional: Task Queue
# =============================================================================
THREATSCOPE_TASKS_MAX_QUEUE_SIZE=100
THREATSCOPE_TASKS_RESULT_TTL=86400
THREATSCOPE_TASKS_RETRY_COUNT=3

# =============================================================================
# Optional: Threat Intelligence
# =============================================================================
THREATSCOPE_THREAT_INTEL_MALWAREBAZAAR_ENABLED=true
THREATSCOPE_THREAT_INTEL_THREATFOX_ENABLED=true
THREATSCOPE_THREAT_INTEL_URLHAUS_ENABLED=true

# =============================================================================
# Optional: Environment
# =============================================================================
THREATSCOPE_ENVIRONMENT=local
THREATSCOPE_DEBUG=false

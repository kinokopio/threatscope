# ThreatScope Configuration
# Copy this file to .env and fill in your values
#
# =============================================================================
# Docker Deployment Quick Start
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Set your ANTHROPIC_API_KEY below
# 3. Run: docker-compose up -d
# 4. Access: http://localhost (Nginx reverse proxy)
#
# Services:
#   - nginx:80      -> Unified entry point
#   - frontend:80   -> React SPA (internal)
#   - backend:8000  -> FastAPI API (internal)
#   - ghidra:8000   -> Ghidra service (internal)
#   - diec:8000     -> File identification (internal)
#
# =============================================================================

# =============================================================================
# Required: AI Configuration
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_TIMEOUT=60

# =============================================================================
# Optional: API Server
# =============================================================================
THREATSCOPE_API_HOST=0.0.0.0
THREATSCOPE_API_PORT=8000
THREATSCOPE_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# Optional: Analysis Settings
# =============================================================================
THREATSCOPE_ANALYSIS_DEFAULT_TIMEOUT=300
THREATSCOPE_ANALYSIS_DYNAMIC_ANALYSIS_TIMEOUT=30
THREATSCOPE_ANALYSIS_ENABLE_DYNAMIC_ANALYSIS=true
THREATSCOPE_ANALYSIS_ENABLE_GHIDRA_ANALYSIS=true
THREATSCOPE_ANALYSIS_YARA_RULES_PATH=rules/yara

# =============================================================================
# Optional: Capa Settings (Capability Detection)
# =============================================================================
THREATSCOPE_CAPA_ENABLED=true
THREATSCOPE_CAPA_RULES_PATH=rules/capa
THREATSCOPE_CAPA_TIMEOUT=60

# =============================================================================
# Optional: Ghidra Settings
# =============================================================================
# Service mode: 'subprocess' (single instance) or 'docker' (multi-instance pool)
THREATSCOPE_GHIDRA_SERVICE_MODE=subprocess

# For Docker mode: number of Ghidra instances to run in parallel
# Each instance can analyze one binary at a time
# Increase for concurrent multi-file analysis
THREATSCOPE_GHIDRA_POOL_SIZE=1

# Docker image for Ghidra service
THREATSCOPE_GHIDRA_DOCKER_IMAGE=threatscope/ghidra:latest

# Memory limit per Ghidra instance
THREATSCOPE_GHIDRA_MEMORY_LIMIT=4g

# Base ports for Ghidra instances (each instance uses base_port + index)
THREATSCOPE_GHIDRA_BASE_HTTP_PORT=8080
THREATSCOPE_GHIDRA_BASE_MCP_PORT=9000

# Startup timeout in seconds
THREATSCOPE_GHIDRA_STARTUP_TIMEOUT=60

# =============================================================================
# Optional: Worker Settings
# =============================================================================
THREATSCOPE_WORKERS_STAGE_1_4=4
THREATSCOPE_WORKERS_STAGE_6=4
THREATSCOPE_WORKERS_DYNAMIC_ANALYSIS=2

# =============================================================================
# Optional: Database
# =============================================================================
THREATSCOPE_DB_PATH=.threatscope/tasks.db
THREATSCOPE_DB_TIMEOUT=30.0

# =============================================================================
# Optional: Task Queue
# =============================================================================
THREATSCOPE_TASKS_MAX_QUEUE_SIZE=100
THREATSCOPE_TASKS_RESULT_TTL=86400
THREATSCOPE_TASKS_RETRY_COUNT=3

# =============================================================================
# Optional: Threat Intelligence
# =============================================================================
THREATSCOPE_THREAT_INTEL_MALWAREBAZAAR_ENABLED=true
THREATSCOPE_THREAT_INTEL_THREATFOX_ENABLED=true
THREATSCOPE_THREAT_INTEL_URLHAUS_ENABLED=true

# =============================================================================
# Optional: Environment
# =============================================================================
THREATSCOPE_ENVIRONMENT=local
THREATSCOPE_DEBUG=false

# =============================================================================
# Optional: GDB Dynamic Analysis (AI-powered debugging)
# =============================================================================
# Path to gdb-mcp repository (for Docker build)
# GDB_MCP_PATH=../gdb-mcp

# Enable GDB MCP server for AI agent to perform dynamic debugging
THREATSCOPE_GDB_ENABLED=false
THREATSCOPE_GDB_SERVICE_MODE=sse
THREATSCOPE_GDB_MCP_URL=http://gdb:8081/sse

# =============================================================================
# Optional: Langfuse Observability
# =============================================================================
# Langfuse provides tracing and monitoring for AI agent calls
# Sign up at https://cloud.langfuse.com or self-host
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# LANGFUSE_HOST=https://cloud.langfuse.com  # or your self-hosted URL
